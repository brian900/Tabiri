# Tabiri — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ── Odds Data ────────────────────────────────────────────────────────────────
REACT_APP_ODDS_API_KEY=your_the_odds_api_key_here

# ── Email Digest (SendGrid) ──────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ── Database (Supabase) ──────────────────────────────────────────────────────
REACT_APP_SUPABASE_URL=https://yourproject.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Weather (OpenWeatherMap) ─────────────────────────────────────────────────
REACT_APP_WEATHER_API_KEY=your_openweathermap_key_here

# ── LinkedIn OAuth ───────────────────────────────────────────────────────────
LINKEDIN_TOKEN=your_linkedin_access_token
LINKEDIN_REFRESH_TOKEN=your_linkedin_refresh_token
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID
LINKEDIN_ARTICLE_URL=https://www.linkedin.com/pulse/your-article-slug
